# Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token

# Channel names to use as mod log (comma-separated, first match wins per server)
# Create a channel with one of these names in each server
MOD_LOG_CHANNEL_NAMES=mod-log,deleted-messages

# Channel IDs to monitor (comma-separated, leave empty for all)
MONITORED_CHANNELS=
